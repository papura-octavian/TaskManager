@model List<TaskManager.Models.TaskItem>

<div class="container mt-4">
    <h2>My Tasks</h2>
    <a href="/Tasks/Create" class="btn btn-primary mb-3">+ New Task</a>

    @if (!Model.Any())
    {
        <p class="text-muted">You don't have any task yet</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
            <tr>
                <th>Title</th>
                <th>Priority</th>
                <th>Deadline</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var task in Model)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Priority</td>
                    <td>@(task.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@(task.IsCompleted ? "✅ Done" : "⏳ In progress...")</td>
                    <td>
                        <a href="/Tasks/Complete/@task.Id"
                           class="btn btn-success btn-sm">
                            Complete
                        </a>
                        <a href="/Tasks/Edit/@task.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                        <a href="/Tasks/Delete/@task.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete task?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>