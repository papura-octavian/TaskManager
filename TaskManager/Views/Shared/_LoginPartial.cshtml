@using Microsoft.AspNetCore.Identity
@inject SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
@inject UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link" asp-area="" asp-controller="Tasks" asp-action="Index">My Tasks</a>
    </li>
    <li class="nav-item">
        <span class="nav-link text-light">Hello, @UserManager.GetUserName(User)!</span>
    </li>
    <li class="nav-item">
        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
            <button type="submit" class="nav-link btn btn-link text-light">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}